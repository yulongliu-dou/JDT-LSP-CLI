{
  "name": "jdt-lsp-cli",
  "version": "1.7.2",
  "description": "CLI tool for Java LSP operations, enabling AI agents to call Java language features from the command line",
  "main": "dist/index.js",
  "bin": {
    "jls": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "node dist/cli.js",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run build",
    "update-version": "node scripts/update-version.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "test:e2e": "jest test/e2e --runInBand",
    "test:mybatis": "jest test/e2e/scenarios/mybatis --runInBand",
    "test:clear-cache": "jest --clearCache",
    "test:cache-status": "node -e \"console.log('Jest cache dir:', require('os').tmpdir() + '/jest_0')\""
  },
  "keywords": [
    "java",
    "lsp",
    "cli",
    "jdt",
    "eclipse",
    "ai",
    "agent",
    "call-hierarchy",
    "language-server"
  ],
  "author": "juqi123 <liuyulong159@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yulongliu-dou/JDT-LSP-CLI.git"
  },
  "homepage": "https://github.com/yulongliu-dou/JDT-LSP-CLI#readme",
  "bugs": {
    "url": "https://github.com/yulongliu-dou/JDT-LSP-CLI/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^14.0.0",
    "glob": "^13.0.0",
    "nanospinner": "^1.2.2",
    "vscode-jsonrpc": "^8.2.0",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.x",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.x"
  }
}
